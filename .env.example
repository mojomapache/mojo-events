# Postgres connection string (Vercel Postgres / Neon). Vercel injects this
# automatically once you attach a Postgres database to the project.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Base URL used to build shareable links (e.g. https://events.mojomapache.com)
NEXT_PUBLIC_BASE_URL="https://events.mojomapache.com"

# Google Cloud API key with "Places API (New)" and "Geocoding API" enabled.
# Optional: without it, nearby-places search is skipped and hosts rely on
# manually added places only.
GOOGLE_PLACES_API_KEY=""

# Anthropic API key, used to label guests' free-text replies (e.g. "bringing
# beer and chips" -> Alcohol, Snacks). Optional: without it, the app falls
# back to a built-in keyword matcher, which works fine for EN/ES.
ANTHROPIC_API_KEY=""
